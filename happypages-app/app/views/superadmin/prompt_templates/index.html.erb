<div class="py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-ops-text">Prompt Templates</h1>
        <p class="text-ops-text-secondary mt-1"><%= @prompt_templates.count %> templates</p>
      </div>
      <%= link_to "New template", new_superadmin_prompt_template_path,
          class: "px-4 py-2 bg-ops-accent text-white rounded-lg text-sm font-medium hover:bg-ops-accent/90 transition-colors" %>
    </div>

    <% if @grouped.any? %>
      <% @grouped.each do |surface, templates| %>
        <div class="mb-8">
          <h2 class="text-lg font-semibold text-ops-text mb-3 capitalize"><%= surface.humanize %></h2>
          <div class="bg-ops-surface rounded-xl border border-ops-border-strong shadow-sm overflow-hidden">
            <table class="min-w-full">
              <thead>
                <tr class="bg-ops-bg border-b border-ops-border">
                  <th class="px-6 py-3 text-left text-xs font-medium text-ops-text-secondary uppercase tracking-wider">Key</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-ops-text-secondary uppercase tracking-wider">Category</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-ops-text-secondary uppercase tracking-wider">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-ops-text-secondary uppercase tracking-wider">Preview</th>
                  <th class="px-6 py-3 text-right text-xs font-medium text-ops-text-secondary uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-ops-border">
                <% templates.each do |template| %>
                  <tr>
                    <td class="px-6 py-4 text-sm font-mono text-ops-text"><%= template.key %></td>
                    <td class="px-6 py-4 text-sm text-ops-text-secondary"><%= template.category || "Universal" %></td>
                    <td class="px-6 py-4">
                      <% if template.active? %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-ops-green/10 text-ops-green">Active</span>
                      <% else %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-ops-surface-hover text-ops-text-tertiary">Inactive</span>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 text-sm text-ops-text-secondary max-w-xs truncate"><%= template.template_text.first(80) %>...</td>
                    <td class="px-6 py-4 text-right">
                      <%= link_to "Edit", edit_superadmin_prompt_template_path(template),
                          class: "text-sm text-ops-accent hover:text-ops-accent/80 mr-3" %>
                      <%= button_to "Delete", superadmin_prompt_template_path(template), method: :delete,
                          data: { turbo_confirm: "Delete template '#{template.key}'?" },
                          class: "text-sm text-ops-red hover:text-ops-red/80" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-16 bg-ops-surface rounded-xl border border-ops-border-strong">
        <p class="text-ops-text-secondary mb-4">No prompt templates yet</p>
        <p class="text-sm text-ops-text-tertiary mb-4">Run <code class="bg-ops-bg px-1.5 py-0.5 rounded text-ops-text-secondary">rails runner db/seeds/prompt_templates.rb</code> to seed defaults</p>
        <%= link_to "Create your first template", new_superadmin_prompt_template_path,
            class: "text-sm text-ops-accent hover:text-ops-accent/80 font-medium" %>
      </div>
    <% end %>
  </div>
</div>
