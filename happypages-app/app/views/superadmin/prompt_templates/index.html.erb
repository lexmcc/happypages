<div class="py-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h1 class="text-base font-semibold text-ops-text">Prompt Templates</h1>
        <p class="text-xs text-ops-text-secondary"><%= @prompt_templates.count %> templates</p>
      </div>
      <%= link_to "New template", new_superadmin_prompt_template_path,
          class: "px-3 py-1.5 bg-ops-accent text-white rounded text-xs font-medium hover:bg-ops-accent/90 transition-colors" %>
    </div>

    <% if @grouped.any? %>
      <% @grouped.each do |surface, templates| %>
        <div class="mb-4">
          <h2 class="text-sm font-semibold text-ops-text mb-2 capitalize"><%= surface.humanize %></h2>
          <div class="border-t border-ops-border">
            <table class="min-w-full">
              <thead>
                <tr class="border-b border-ops-border">
                  <th class="px-4 py-2 text-left text-[11px] font-medium text-ops-text-secondary uppercase tracking-wider">Key</th>
                  <th class="px-4 py-2 text-left text-[11px] font-medium text-ops-text-secondary uppercase tracking-wider">Category</th>
                  <th class="px-4 py-2 text-left text-[11px] font-medium text-ops-text-secondary uppercase tracking-wider">Status</th>
                  <th class="px-4 py-2 text-left text-[11px] font-medium text-ops-text-secondary uppercase tracking-wider">Preview</th>
                  <th class="px-4 py-2 text-right text-[11px] font-medium text-ops-text-secondary uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-ops-border">
                <% templates.each do |template| %>
                  <tr>
                    <td class="px-4 py-1.5 text-xs font-mono text-ops-text"><%= template.key %></td>
                    <td class="px-4 py-1.5 text-xs text-ops-text-secondary"><%= template.category || "Universal" %></td>
                    <td class="px-4 py-1.5">
                      <% if template.active? %>
                        <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-ops-green/10 text-ops-green">Active</span>
                      <% else %>
                        <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-ops-surface-hover text-ops-text-tertiary">Inactive</span>
                      <% end %>
                    </td>
                    <td class="px-4 py-1.5 text-xs text-ops-text-secondary max-w-xs truncate"><%= template.template_text.first(80) %>...</td>
                    <td class="px-4 py-1.5 text-right">
                      <%= link_to "Edit", edit_superadmin_prompt_template_path(template),
                          class: "text-xs text-ops-accent hover:text-ops-accent/80 mr-2" %>
                      <%= button_to "Delete", superadmin_prompt_template_path(template), method: :delete,
                          data: { turbo_confirm: "Delete template '#{template.key}'?" },
                          class: "text-xs text-ops-red hover:text-ops-red/80" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-12 border border-ops-border rounded-md">
        <p class="text-ops-text-secondary text-xs mb-3">No prompt templates yet</p>
        <p class="text-[11px] text-ops-text-tertiary mb-3">Run <code class="bg-ops-bg px-1 py-px rounded text-ops-text-secondary">rails runner db/seeds/prompt_templates.rb</code> to seed defaults</p>
        <%= link_to "Create your first template", new_superadmin_prompt_template_path,
            class: "text-xs text-ops-accent hover:text-ops-accent/80 font-medium" %>
      </div>
    <% end %>
  </div>
</div>
