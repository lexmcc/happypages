<%# Search by referral code %>
<div class="mb-4">
  <%= form_with url: superadmin_shop_path(@shop), method: :get, class: "flex gap-2 items-end", data: { turbo_frame: "_top" } do %>
    <div class="flex-1 max-w-xs">
      <label for="code" class="block text-[11px] font-medium text-ops-text-secondary mb-1">Search by code</label>
      <input type="text" name="code" id="code" value="<%= params[:code] %>" placeholder="e.g. Sarah042"
        class="w-full px-2 py-1 bg-ops-bg border border-ops-border-strong rounded text-xs text-ops-text placeholder-ops-text-tertiary focus:outline-none focus:ring-2 focus:ring-ops-accent/20 focus:border-ops-accent">
    </div>
    <button type="submit" class="px-3 py-1.5 bg-ops-accent text-white rounded text-xs font-medium hover:bg-ops-accent/90 transition-colors">
      Search
    </button>
    <% if params[:code].present? %>
      <%= link_to "Clear", superadmin_shop_path(@shop), class: "px-3 py-1.5 text-ops-text-secondary text-xs hover:text-ops-text transition-colors" %>
    <% end %>
  <% end %>
</div>

<div class="border-t border-ops-border">
  <table class="min-w-full">
    <thead>
      <tr>
        <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Code</th>
        <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">First Name</th>
        <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Usages</th>
        <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Rewards</th>
        <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Created</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-ops-border">
      <% @referrals.each do |referral| %>
        <tr>
          <td class="px-4 py-1.5 text-xs font-mono text-ops-text"><%= referral.referral_code %></td>
          <td class="px-4 py-1.5 text-xs text-ops-text-secondary"><%= referral.first_name %></td>
          <td class="px-4 py-1.5 text-xs text-ops-text tabular-nums"><%= referral.usage_count || 0 %></td>
          <td class="px-4 py-1.5 text-xs text-ops-text tabular-nums"><%= referral.referral_rewards.size %></td>
          <td class="px-4 py-1.5 text-xs text-ops-text-secondary"><%= referral.created_at.strftime("%b %d, %Y") %></td>
        </tr>
      <% end %>

      <% if @referrals.empty? %>
        <tr>
          <td colspan="5" class="px-4 py-6 text-center text-ops-text-tertiary text-xs">
            <%= params[:code].present? ? "No referrals matching \"#{params[:code]}\"" : "No referrals yet" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
