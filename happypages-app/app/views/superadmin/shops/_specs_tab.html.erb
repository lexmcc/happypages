<div class="bg-ops-surface rounded-xl border border-ops-border-strong shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b border-ops-border">
    <h3 class="text-sm font-semibold text-ops-text">Specs Projects</h3>
  </div>

  <% if @specs_projects.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-ops-border">
          <th class="text-left px-6 py-3 text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Project</th>
          <th class="text-left px-6 py-3 text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Sessions</th>
          <th class="text-left px-6 py-3 text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Latest Status</th>
          <th class="text-left px-6 py-3 text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Cards</th>
          <th class="text-left px-6 py-3 text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ops-border">
        <% @specs_projects.each do |project| %>
          <tr class="hover:bg-ops-surface-hover">
            <td class="px-6 py-4 text-sm font-medium text-ops-text"><%= project.name %></td>
            <td class="px-6 py-4 text-sm text-ops-text-secondary"><%= project.sessions.size %></td>
            <td class="px-6 py-4 text-sm">
              <% latest = project.sessions.max_by(&:version) %>
              <% if latest %>
                <% status_color = latest.status == "active" ? "text-ops-green" : "text-ops-text-secondary" %>
                <span class="<%= status_color %>"><%= latest.status %></span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm">
              <% card_counts = project.cards.group_by(&:status).transform_values(&:count) %>
              <div class="flex gap-2">
                <% Specs::Card::STATUSES.each do |status| %>
                  <% count = card_counts[status] || 0 %>
                  <% next if count == 0 %>
                  <% badge_color = case status
                       when "backlog" then "bg-ops-surface-hover text-ops-text-secondary"
                       when "in_progress" then "bg-ops-accent/10 text-ops-accent"
                       when "review" then "bg-ops-amber/10 text-ops-amber"
                       when "done" then "bg-ops-green/10 text-ops-green"
                       end %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[11px] font-medium <%= badge_color %>">
                    <%= count %> <%= status.gsub("_", " ") %>
                  </span>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-4 text-xs text-ops-text-tertiary"><%= project.created_at.strftime("%b %d, %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-6 py-12 text-center text-sm text-ops-text-tertiary">No specs projects for this shop.</div>
  <% end %>
</div>
