<div class="border-t border-ops-border">
  <table class="min-w-full">
    <tbody class="divide-y divide-ops-border">
      <tr>
        <td class="px-4 py-1.5 text-xs font-medium text-ops-text-secondary w-48">Platform</td>
        <td class="px-4 py-1.5 text-xs text-ops-text"><%= @shop.platform_type.capitalize %></td>
      </tr>
      <tr>
        <td class="px-4 py-1.5 text-xs font-medium text-ops-text-secondary">Access Token</td>
        <td class="px-4 py-1.5">
          <% if @credential&.shopify_access_token.present? %>
            <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-ops-green/10 text-ops-green">Present</span>
          <% else %>
            <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-ops-red/10 text-ops-red">Missing</span>
          <% end %>
        </td>
      </tr>
      <tr>
        <td class="px-4 py-1.5 text-xs font-medium text-ops-text-secondary">Awtomic</td>
        <td class="px-4 py-1.5">
          <% if @credential&.awtomic_api_key.present? %>
            <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-ops-green/10 text-ops-green">Connected</span>
          <% else %>
            <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-ops-surface-hover text-ops-text-tertiary">Not connected</span>
          <% end %>
        </td>
      </tr>
      <tr>
        <td class="px-4 py-1.5 text-xs font-medium text-ops-text-secondary">Klaviyo</td>
        <td class="px-4 py-1.5">
          <% if @credential&.klaviyo_api_key.present? %>
            <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-ops-green/10 text-ops-green">Connected</span>
          <% else %>
            <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-ops-surface-hover text-ops-text-tertiary">Not connected</span>
          <% end %>
        </td>
      </tr>
      <tr>
        <td class="px-4 py-1.5 text-xs font-medium text-ops-text-secondary">Shop Slug</td>
        <td class="px-4 py-1.5 text-xs text-ops-text font-mono"><%= @shop.slug || "—" %></td>
      </tr>
      <tr>
        <td class="px-4 py-1.5 text-xs font-medium text-ops-text-secondary">Storefront URL</td>
        <td class="px-4 py-1.5 text-xs text-ops-text"><%= @shop.customer_facing_url %></td>
      </tr>
    </tbody>
  </table>
</div>
