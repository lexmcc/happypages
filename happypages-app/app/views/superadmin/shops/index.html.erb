<div class="py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-ops-text">Shops</h1>
      <p class="text-ops-text-secondary mt-1"><%= @shops.count %> total</p>
    </header>

    <%# Search %>
    <div class="mb-6">
      <%= form_with url: superadmin_shops_path, method: :get, class: "flex gap-2" do |f| %>
        <%= f.search_field :q, value: params[:q], placeholder: "Search by name or domain...",
            class: "flex-1 px-3 py-2 text-sm border border-ops-border-strong rounded-lg bg-ops-surface text-ops-text placeholder-ops-text-tertiary focus:ring-ops-accent focus:border-ops-accent" %>
        <% if params[:status].present? %>
          <%= f.hidden_field :status, value: params[:status] %>
        <% end %>
        <%= f.submit "Search", class: "px-4 py-2 text-sm font-medium rounded-lg bg-ops-accent text-white hover:bg-ops-accent/90 cursor-pointer" %>
        <% if params[:q].present? %>
          <%= link_to "Clear", superadmin_shops_path(status: params[:status]), class: "px-4 py-2 text-sm rounded-lg border border-ops-border-strong hover:bg-ops-surface-hover text-ops-text-secondary flex items-center" %>
        <% end %>
      <% end %>
    </div>

    <%# Status filter tabs %>
    <div class="flex gap-2 mb-6">
      <% [["All", nil], ["Active", "active"], ["Suspended", "suspended"], ["Uninstalled", "uninstalled"]].each do |label, status| %>
        <% active = params[:status] == status %>
        <%= link_to label,
            superadmin_shops_path(status: status),
            class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{active ? 'bg-ops-accent text-white' : 'bg-ops-surface text-ops-text-secondary border border-ops-border-strong hover:bg-ops-surface-hover'}" %>
      <% end %>
    </div>

    <%# Shop table %>
    <div class="bg-ops-surface rounded-xl border border-ops-border-strong shadow-sm overflow-hidden">
      <table class="min-w-full divide-y divide-ops-border-strong">
        <thead class="bg-ops-bg">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Shop</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Platform</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Installed</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Referrals</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ops-text-secondary uppercase tracking-wider">Slug</th>
            <th class="px-6 py-3 text-right text-xs font-semibold text-ops-text-secondary uppercase tracking-wider"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-ops-border">
          <% @shops.each do |shop| %>
            <tr class="hover:bg-ops-surface-hover transition-colors">
              <td class="px-6 py-4">
                <%= link_to superadmin_shop_path(shop), class: "block" do %>
                  <p class="text-sm font-medium text-ops-text"><%= shop.name %></p>
                  <p class="text-xs text-ops-text-secondary"><%= shop.domain %></p>
                <% end %>
              </td>
              <td class="px-6 py-4">
                <% badge_class = case shop.status
                   when "active" then "bg-ops-green/10 text-ops-green"
                   when "suspended" then "bg-ops-red/10 text-ops-red"
                   when "uninstalled" then "bg-ops-surface-hover text-ops-text-tertiary"
                   end %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= badge_class %>">
                  <%= shop.status %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-ops-text-secondary"><%= shop.platform_type %></td>
              <td class="px-6 py-4 text-sm text-ops-text-secondary"><%= shop.created_at.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4 text-sm text-ops-text font-medium tabular-nums"><%= @referral_counts[shop.id] || 0 %></td>
              <td class="px-6 py-4 text-sm text-ops-text-secondary font-mono"><%= shop.slug %></td>
              <td class="px-6 py-4 text-right">
                <%= link_to "Manage →", manage_superadmin_shop_path(shop), class: "text-sm font-medium text-ops-accent hover:text-ops-accent/80" %>
              </td>
            </tr>
          <% end %>

          <% if @shops.empty? %>
            <tr>
              <td colspan="7" class="px-6 py-12 text-center text-ops-text-tertiary">No shops found</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
