<div class="py-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <header class="mb-4">
      <h1 class="text-base font-semibold text-ops-text">Shops</h1>
      <p class="text-xs text-ops-text-secondary"><%= @shops.count %> total</p>
    </header>

    <%# Search %>
    <div class="mb-4">
      <%= form_with url: superadmin_shops_path, method: :get, class: "flex gap-2" do |f| %>
        <%= f.search_field :q, value: params[:q], placeholder: "Search by name or domain...",
            class: "flex-1 px-2 py-1 text-xs border border-ops-border-strong rounded bg-ops-surface text-ops-text placeholder-ops-text-tertiary focus:ring-ops-accent focus:border-ops-accent" %>
        <% if params[:status].present? %>
          <%= f.hidden_field :status, value: params[:status] %>
        <% end %>
        <%= f.submit "Search", class: "px-3 py-1.5 text-xs font-medium rounded bg-ops-accent text-white hover:bg-ops-accent/90 cursor-pointer" %>
        <% if params[:q].present? %>
          <%= link_to "Clear", superadmin_shops_path(status: params[:status]), class: "px-3 py-1.5 text-xs rounded border border-ops-border-strong hover:bg-ops-surface-hover text-ops-text-secondary flex items-center" %>
        <% end %>
      <% end %>
    </div>

    <%# Status filter tabs %>
    <div class="flex gap-1.5 mb-4">
      <% [["All", nil], ["Active", "active"], ["Suspended", "suspended"], ["Uninstalled", "uninstalled"]].each do |label, status| %>
        <% active = params[:status] == status %>
        <%= link_to label,
            superadmin_shops_path(status: status),
            class: "px-2 py-1 rounded text-xs font-medium transition-colors #{active ? 'bg-ops-accent text-white' : 'bg-ops-surface text-ops-text-secondary border border-ops-border-strong hover:bg-ops-surface-hover'}" %>
      <% end %>
    </div>

    <%# Shop table %>
    <div class="border-t border-ops-border">
      <table class="min-w-full">
        <thead>
          <tr>
            <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Shop</th>
            <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Status</th>
            <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Platform</th>
            <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Installed</th>
            <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Referrals</th>
            <th class="px-4 py-2 text-left text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider">Slug</th>
            <th class="px-4 py-2 text-right text-[11px] font-semibold text-ops-text-secondary uppercase tracking-wider"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-ops-border">
          <% @shops.each do |shop| %>
            <tr class="hover:bg-ops-surface-hover transition-colors">
              <td class="px-4 py-1.5">
                <%= link_to superadmin_shop_path(shop), class: "block" do %>
                  <p class="text-xs font-medium text-ops-text"><%= shop.name %></p>
                  <p class="text-[11px] text-ops-text-secondary"><%= shop.domain %></p>
                <% end %>
              </td>
              <td class="px-4 py-1.5">
                <% badge_class = case shop.status
                   when "active" then "bg-ops-green/10 text-ops-green"
                   when "suspended" then "bg-ops-red/10 text-ops-red"
                   when "uninstalled" then "bg-ops-surface-hover text-ops-text-tertiary"
                   end %>
                <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium <%= badge_class %>">
                  <%= shop.status %>
                </span>
              </td>
              <td class="px-4 py-1.5 text-xs text-ops-text-secondary"><%= shop.platform_type %></td>
              <td class="px-4 py-1.5 text-xs text-ops-text-secondary"><%= shop.created_at.strftime("%b %d, %Y") %></td>
              <td class="px-4 py-1.5 text-xs text-ops-text font-medium tabular-nums"><%= @referral_counts[shop.id] || 0 %></td>
              <td class="px-4 py-1.5 text-xs text-ops-text-secondary font-mono"><%= shop.slug %></td>
              <td class="px-4 py-1.5 text-right">
                <%= link_to "Manage →", manage_superadmin_shop_path(shop), class: "text-xs font-medium text-ops-accent hover:text-ops-accent/80" %>
              </td>
            </tr>
          <% end %>

          <% if @shops.empty? %>
            <tr>
              <td colspan="7" class="px-4 py-8 text-center text-ops-text-tertiary text-xs">No shops found</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
