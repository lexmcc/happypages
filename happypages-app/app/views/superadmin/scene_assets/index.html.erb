<div class="py-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h1 class="text-base font-semibold text-ops-text">Scene Assets</h1>
        <p class="text-xs text-ops-text-secondary"><%= @scene_assets.count %> scenes in library</p>
      </div>
      <%= link_to "Add scene", new_superadmin_scene_asset_path,
          class: "px-3 py-1.5 bg-ops-accent text-white rounded text-xs font-medium hover:bg-ops-accent/90 transition-colors" %>
    </div>

    <%# Category filter %>
    <div class="flex gap-1.5 mb-4 flex-wrap">
      <%= link_to "All", superadmin_scene_assets_path,
          class: "px-2 py-1 rounded text-xs font-medium transition-colors #{params[:category].blank? ? 'bg-ops-accent text-white' : 'bg-ops-surface text-ops-text-secondary border border-ops-border-strong hover:bg-ops-surface-hover'}" %>
      <% SceneAsset::CATEGORIES.each do |cat| %>
        <%= link_to cat.capitalize, superadmin_scene_assets_path(category: cat),
            class: "px-2 py-1 rounded text-xs font-medium transition-colors #{params[:category] == cat ? 'bg-ops-accent text-white' : 'bg-ops-surface text-ops-text-secondary border border-ops-border-strong hover:bg-ops-surface-hover'}" %>
      <% end %>
    </div>

    <% if @scene_assets.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @scene_assets.each do |asset| %>
          <div class="bg-ops-surface rounded-md border border-ops-border-strong overflow-hidden">
            <% if asset.file.attached? %>
              <div class="aspect-video bg-ops-bg">
                <%= image_tag asset.file.variant(resize_to_fill: [600, 340], format: :webp),
                    class: "w-full h-full object-cover", loading: "lazy" %>
              </div>
            <% else %>
              <div class="aspect-video bg-ops-bg flex items-center justify-center">
                <span class="text-ops-text-tertiary text-xs">No image</span>
              </div>
            <% end %>

            <div class="p-3">
              <div class="flex items-center gap-1.5 mb-1.5">
                <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-ops-accent/10 text-ops-accent">
                  <%= asset.category %>
                </span>
                <% if asset.mood.present? %>
                  <span class="inline-flex items-center px-1.5 py-px rounded text-[11px] font-medium bg-purple-500/10 text-purple-400">
                    <%= asset.mood %>
                  </span>
                <% end %>
              </div>

              <p class="text-xs text-ops-text-secondary line-clamp-2 mb-2"><%= asset.description %></p>

              <% if asset.tags.any? %>
                <div class="flex flex-wrap gap-1 mb-2">
                  <% asset.tags.each do |tag| %>
                    <span class="px-1.5 py-px bg-ops-surface-hover text-ops-text-tertiary rounded text-[11px]"><%= tag %></span>
                  <% end %>
                </div>
              <% end %>

              <div class="flex gap-2">
                <%= link_to "Edit", edit_superadmin_scene_asset_path(asset),
                    class: "text-xs text-ops-accent hover:text-ops-accent/80" %>
                <%= button_to "Delete", superadmin_scene_asset_path(asset), method: :delete,
                    data: { turbo_confirm: "Delete this scene asset?" },
                    class: "text-xs text-ops-red hover:text-ops-red/80" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 border border-ops-border rounded-md">
        <p class="text-ops-text-secondary text-xs mb-3">No scene assets yet</p>
        <%= link_to "Upload your first scene", new_superadmin_scene_asset_path,
            class: "text-xs text-ops-accent hover:text-ops-accent/80 font-medium" %>
      </div>
    <% end %>
  </div>
</div>
