<%= form_with(model: [:superadmin, scene_asset], class: "space-y-4") do |f| %>
  <% if scene_asset.errors.any? %>
    <div class="px-3 py-2 bg-ops-red/10 border border-ops-red/20 rounded text-ops-red text-xs">
      <ul class="list-disc pl-4 space-y-1">
        <% scene_asset.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="border border-ops-border rounded-md p-4 space-y-4">
    <div>
      <label class="block text-xs font-medium text-ops-text-secondary mb-1">Image</label>
      <% if scene_asset.file.attached? %>
        <div class="mb-2">
          <%= image_tag scene_asset.file.variant(resize_to_fill: [400, 230], format: :webp),
              class: "rounded-md border border-ops-border-strong" %>
        </div>
      <% end %>
      <%= f.file_field :file, accept: "image/jpeg,image/png,image/webp",
          class: "block w-full text-xs text-ops-text-secondary file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-xs file:font-medium file:bg-ops-accent file:text-white hover:file:bg-ops-accent/90" %>
    </div>

    <div>
      <label class="block text-xs font-medium text-ops-text-secondary mb-1">Category</label>
      <%= f.select :category, SceneAsset::CATEGORIES.map { |c| [c.capitalize, c] },
          { prompt: "Select category" },
          class: "block w-full rounded border-ops-border-strong bg-ops-bg text-ops-text shadow-sm text-xs focus:border-ops-accent focus:ring-ops-accent" %>
    </div>

    <div>
      <label class="block text-xs font-medium text-ops-text-secondary mb-1">Mood</label>
      <%= f.select :mood, SceneAsset::MOODS.map { |m| [m.capitalize, m] },
          { include_blank: "None" },
          class: "block w-full rounded border-ops-border-strong bg-ops-bg text-ops-text shadow-sm text-xs focus:border-ops-accent focus:ring-ops-accent" %>
    </div>

    <div>
      <label class="block text-xs font-medium text-ops-text-secondary mb-1">Description</label>
      <%= f.text_area :description, rows: 3, placeholder: "Two friends sharing a drink at a sunlit cafe table",
          class: "block w-full rounded border-ops-border-strong bg-ops-bg text-ops-text placeholder-ops-text-tertiary shadow-sm text-xs focus:border-ops-accent focus:ring-ops-accent" %>
      <p class="text-[11px] text-ops-text-tertiary mt-1">Describe the scene — used in prompt generation</p>
    </div>

    <div>
      <label class="block text-xs font-medium text-ops-text-secondary mb-1">Tags</label>
      <%= f.text_field :tag_list, value: scene_asset.tag_list, placeholder: "sharing, coffee, warm, friends",
          class: "block w-full rounded border-ops-border-strong bg-ops-bg text-ops-text placeholder-ops-text-tertiary shadow-sm text-xs focus:border-ops-accent focus:ring-ops-accent" %>
      <p class="text-[11px] text-ops-text-tertiary mt-1">Comma-separated — used for matching scenes to brands</p>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <%= f.submit scene_asset.persisted? ? "Update scene" : "Create scene",
        class: "px-3 py-1.5 bg-ops-accent text-white rounded text-xs font-medium hover:bg-ops-accent/90 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", superadmin_scene_assets_path,
        class: "px-3 py-1.5 text-ops-text-secondary text-xs font-medium hover:text-ops-text" %>
  </div>
<% end %>
