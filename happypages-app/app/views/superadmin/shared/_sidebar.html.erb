<div data-controller="sidebar">
  <%# Mobile hamburger button %>
  <button
    data-action="click->sidebar#toggle"
    class="lg:hidden fixed top-4 left-4 z-50 p-2 bg-ops-surface border border-ops-border-strong rounded shadow-lg"
    aria-label="Toggle navigation"
  >
    <svg class="size-3.5 text-ops-text-secondary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
  </button>

  <%# Backdrop %>
  <div
    data-sidebar-target="backdrop"
    data-action="click->sidebar#close"
    class="hidden fixed inset-0 bg-black/50 z-30 lg:hidden"
  ></div>

  <%# Sidebar %>
  <aside
    data-sidebar-target="sidebar"
    class="fixed lg:sticky top-0 left-0 z-40 h-screen w-52 bg-ops-surface border-r border-ops-border-strong flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-200"
  >
    <%# Header with badge %>
    <div class="px-4 py-3 border-b border-ops-border-strong">
      <div class="flex items-center gap-2">
        <img src="/refrral-app-icon-large.png" alt="Happypages" class="size-6 rounded-lg">
        <div>
          <span class="text-sm font-semibold text-ops-text">Happypages</span>
          <span class="ml-1.5 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-ops-amber/20 text-ops-amber border border-ops-amber/30">Super</span>
        </div>
      </div>
    </div>

    <%# Navigation %>
    <nav class="flex-1 px-3 py-3 space-y-0.5 overflow-y-auto">
      <%= link_to superadmin_ops_path, class: "flex items-center gap-2 px-3 py-1.5 rounded text-sm font-medium transition-colors #{request.path.start_with?('/superadmin/ops') ? 'bg-ops-accent/15 text-ops-accent' : 'text-ops-text-secondary hover:bg-ops-surface-hover hover:text-ops-text'}", tabindex: "-1", data: { tooltip: "Ops Dashboard" } do %>
        <svg class="size-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
        <span class="nav-label">Ops Dashboard</span>
      <% end %>

      <%= link_to superadmin_root_path, class: "flex items-center gap-2 px-3 py-1.5 rounded text-sm font-medium transition-colors #{request.path.start_with?('/superadmin/shops') || request.path == '/superadmin' || request.path == '/superadmin/' ? 'bg-ops-surface-hover text-ops-text' : 'text-ops-text-secondary hover:bg-ops-surface-hover hover:text-ops-text'}", tabindex: "-1", data: { tooltip: "Shops" } do %>
        <svg class="size-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z"></path>
        </svg>
        <span class="nav-label">Shops</span>
      <% end %>

      <div class="pt-4 pb-2 px-3">
        <p class="text-[10px] font-bold uppercase tracking-wider text-ops-text-tertiary">Specs</p>
      </div>

      <%= link_to superadmin_specs_overview_index_path, class: "flex items-center gap-2 px-3 py-1.5 rounded text-sm font-medium transition-colors #{request.path.start_with?('/superadmin/specs_overview') ? 'bg-ops-surface-hover text-ops-text' : 'text-ops-text-secondary hover:bg-ops-surface-hover hover:text-ops-text'}", tabindex: "-1", data: { tooltip: "Overview" } do %>
        <svg class="size-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="3" y="3" width="7" height="7" rx="1"></rect>
          <rect x="14" y="3" width="7" height="7" rx="1"></rect>
          <rect x="3" y="14" width="7" height="7" rx="1"></rect>
          <rect x="14" y="14" width="7" height="7" rx="1"></rect>
        </svg>
        <span class="nav-label">Overview</span>
      <% end %>

      <%= link_to superadmin_organisations_path, class: "flex items-center gap-2 px-3 py-1.5 rounded text-sm font-medium transition-colors #{request.path.start_with?('/superadmin/organisations') ? 'bg-ops-surface-hover text-ops-text' : 'text-ops-text-secondary hover:bg-ops-surface-hover hover:text-ops-text'}", tabindex: "-1", data: { tooltip: "Organisations" } do %>
        <svg class="size-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path stroke-linecap="round" stroke-linejoin="round" d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 3.13a4 4 0 0 1 0 7.75"></path>
        </svg>
        <span class="nav-label">Organisations</span>
      <% end %>

      <div class="pt-4 pb-2 px-3">
        <p class="text-[10px] font-bold uppercase tracking-wider text-ops-text-tertiary">AI Imagery</p>
      </div>

      <%= link_to superadmin_scene_assets_path, class: "flex items-center gap-2 px-3 py-1.5 rounded text-sm font-medium transition-colors #{request.path.start_with?('/superadmin/scene_assets') ? 'bg-ops-surface-hover text-ops-text' : 'text-ops-text-secondary hover:bg-ops-surface-hover hover:text-ops-text'}", tabindex: "-1", data: { tooltip: "Scene Assets" } do %>
        <svg class="size-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <circle cx="8.5" cy="8.5" r="1.5"></circle>
          <polyline points="21 15 16 10 5 21"></polyline>
        </svg>
        <span class="nav-label">Scene Assets</span>
      <% end %>

      <%= link_to superadmin_prompt_templates_path, class: "flex items-center gap-2 px-3 py-1.5 rounded text-sm font-medium transition-colors #{request.path.start_with?('/superadmin/prompt_templates') ? 'bg-ops-surface-hover text-ops-text' : 'text-ops-text-secondary hover:bg-ops-surface-hover hover:text-ops-text'}", tabindex: "-1", data: { tooltip: "Prompt Templates" } do %>
        <svg class="size-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
        </svg>
        <span class="nav-label">Prompt Templates</span>
      <% end %>
    </nav>

    <%# Logout %>
    <div class="px-4 py-3 border-t border-ops-border-strong">
      <p class="text-xs text-ops-text-tertiary truncate mb-2"><%= session[:super_admin_email] %></p>
      <%= button_to "Logout", superadmin_logout_path, method: :delete, class: "text-xs text-ops-text-secondary hover:text-ops-text transition-colors", tabindex: "-1" %>
    </div>
  </aside>
</div>
