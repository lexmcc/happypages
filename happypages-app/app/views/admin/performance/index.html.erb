<%# Control bar with period selector %>
<div class="sticky top-0 z-30 bg-[#f4f4f0]/95 backdrop-blur-sm border-b border-black/5" data-controller="analytics-filter">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3">
    <div class="flex flex-wrap items-center gap-3">
      <span class="text-sm font-semibold text-gray-900">referral performance.</span>

      <div class="h-5 w-px bg-gray-200 hidden sm:block"></div>

      <%# Period buttons %>
      <div class="flex gap-1">
        <% [["today", "Today"], ["7d", "7d"], ["30d", "30d"], ["90d", "90d"]].each do |value, label| %>
          <button
            data-action="click->analytics-filter#setPeriod"
            data-period="<%= value %>"
            class="px-3 py-1 rounded-md text-xs font-medium transition-colors <%= @period == value ? 'bg-[#ff584d] text-white' : 'text-gray-600 hover:bg-white hover:shadow-sm' %>"
          >
            <%= label %>
          </button>
        <% end %>
      </div>

      <%# Comparison toggle %>
      <label class="flex items-center gap-1.5 text-xs text-gray-500 cursor-pointer select-none">
        <input
          type="checkbox"
          data-analytics-filter-target="compare"
          data-action="change->analytics-filter#toggleCompare"
          <%= "checked" if @compare %>
          class="rounded border-gray-300 text-[#ff584d] focus:ring-[#ff584d]/20 h-3.5 w-3.5"
        >
        vs previous
      </label>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 space-y-6">

  <% if @empty %>
    <%# Empty state %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-12 text-center">
      <div class="text-4xl mb-4">📊</div>
      <h2 class="text-lg font-semibold text-gray-900 mb-2">no data yet.</h2>
      <p class="text-sm text-gray-500 max-w-md mx-auto mb-6">
        once your referral program is live, you'll see funnel metrics, conversion rates, and revenue data here.
      </p>
      <div class="text-left max-w-sm mx-auto space-y-3">
        <div class="flex items-center gap-3 text-sm">
          <span class="w-5 h-5 rounded-full bg-gray-100 flex items-center justify-center text-xs text-gray-400">1</span>
          <span class="text-gray-600">create a referral campaign</span>
        </div>
        <div class="flex items-center gap-3 text-sm">
          <span class="w-5 h-5 rounded-full bg-gray-100 flex items-center justify-center text-xs text-gray-400">2</span>
          <span class="text-gray-600">install the checkout extension</span>
        </div>
        <div class="flex items-center gap-3 text-sm">
          <span class="w-5 h-5 rounded-full bg-gray-100 flex items-center justify-center text-xs text-gray-400">3</span>
          <span class="text-gray-600">wait for your first share</span>
        </div>
      </div>
    </div>
  <% else %>

    <%# KPI cards %>
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
      <%= render "admin/performance/kpi_card",
        label: "Extension Loads",
        value: @data[:kpis][:extension_loads][:value],
        format: :number,
        change: @data[:kpis][:extension_loads][:change],
        metric_key: "extension_loads",
        sparkline_data: @data[:sparklines][:extension_loads],
        color: "#0072B2",
        active: @metric == "extension_loads" %>

      <%= render "admin/performance/kpi_card",
        label: "Share Rate",
        value: @data[:kpis][:share_rate][:value],
        format: :percent,
        change: @data[:kpis][:share_rate][:change],
        metric_key: "shares",
        sparkline_data: @data[:sparklines][:shares],
        color: "#E69F00",
        active: @metric == "shares" %>

      <%= render "admin/performance/kpi_card",
        label: "Page Visits",
        value: @data[:kpis][:page_visits][:value],
        format: :number,
        change: @data[:kpis][:page_visits][:change],
        metric_key: "page_visits",
        sparkline_data: @data[:sparklines][:page_visits],
        color: "#56B4E9",
        active: @metric == "page_visits" %>

      <%= render "admin/performance/kpi_card",
        label: "Referred Orders",
        value: @data[:kpis][:referred_orders][:value],
        format: :number,
        change: @data[:kpis][:referred_orders][:change],
        metric_key: "referred_orders",
        sparkline_data: @data[:sparklines][:referred_orders],
        color: "#009E73",
        active: @metric == "referred_orders" %>

      <%= render "admin/performance/kpi_card",
        label: "Conversion Rate",
        value: @data[:kpis][:conversion_rate][:value],
        format: :percent,
        change: @data[:kpis][:conversion_rate][:change],
        metric_key: "referred_orders",
        sparkline_data: nil,
        color: "#6b7280" %>

      <%= render "admin/performance/kpi_card",
        label: "Referred Revenue",
        value: @data[:kpis][:referred_revenue][:value],
        format: :currency,
        change: @data[:kpis][:referred_revenue][:change],
        metric_key: "referred_revenue",
        sparkline_data: @data[:sparklines][:referred_revenue],
        color: "#D55E00",
        active: @metric == "referred_revenue" %>
    </div>

    <%# Time series chart %>
    <div class="bg-white rounded-xl shadow-sm p-5">
      <div
        class="h-[200px] sm:h-[280px]"
        data-controller="analytics-chart"
        data-analytics-chart-metrics-value="<%= @data[:time_series].to_json %>"
        data-analytics-chart-active-metric-value="<%= @metric %>"
      >
        <canvas data-analytics-chart-target="canvas"></canvas>
      </div>
    </div>

    <%# Funnel + Source breakdown row %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

      <%# Funnel %>
      <div class="lg:col-span-2 bg-white rounded-xl shadow-sm p-5">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">referral funnel.</h3>
        <div class="space-y-3">
          <% max_value = [@data[:funnel][:stages].map { |s| s[:value] }.max, 1].max %>
          <% rates = @data[:funnel][:conversion_rates] %>
          <% rate_keys = [:load_to_visit, :visit_to_share, :share_to_order] %>

          <% @data[:funnel][:stages].each_with_index do |stage, i| %>
            <div>
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-medium text-gray-600"><%= stage[:label] %></span>
                <span class="text-sm font-bold text-gray-900 tabular-nums"><%= number_with_delimiter(stage[:value]) %></span>
              </div>
              <div class="h-6 bg-gray-100 rounded-full overflow-hidden">
                <% pct = (stage[:value].to_f / max_value * 100).round(1) %>
                <div class="h-full rounded-full bg-[#ff584d] transition-all" style="width: <%= [pct, 2].max %>%"></div>
              </div>
            </div>

            <% if i < rate_keys.length %>
              <div class="flex items-center gap-2 pl-4 -my-1">
                <svg class="w-3 h-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                <span class="text-xs text-gray-400 tabular-nums"><%= rates[rate_keys[i]] %>% conversion</span>
              </div>
            <% end %>
          <% end %>

          <div class="pt-2 border-t border-gray-100 flex items-center justify-between">
            <span class="text-xs font-medium text-gray-500">overall conversion</span>
            <span class="text-sm font-bold text-[#ff584d] tabular-nums"><%= rates[:overall] %>%</span>
          </div>
        </div>
      </div>

      <%# Source breakdown %>
      <div class="bg-white rounded-xl shadow-sm p-5">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">page visit sources.</h3>
        <div class="space-y-3">
          <% @data[:source_breakdown].each do |source| %>
            <div>
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-medium text-gray-600"><%= source[:label] %></span>
                <span class="text-xs text-gray-400 tabular-nums"><%= source[:count] %> (<%= source[:pct] %>%)</span>
              </div>
              <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full bg-[#ff584d] transition-all" style="width: <%= [source[:pct], 2].max %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Top referrers %>
    <% if @data[:top_referrers].any? %>
      <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100">
          <h3 class="text-sm font-semibold text-gray-900">top referrers.</h3>
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="text-xs text-gray-500 uppercase tracking-wide border-b border-gray-50">
              <th class="text-left px-5 py-2 font-medium">#</th>
              <th class="text-left px-5 py-2 font-medium">Code</th>
              <th class="text-right px-5 py-2 font-medium">Uses</th>
              <th class="text-right px-5 py-2 font-medium">Revenue</th>
            </tr>
          </thead>
          <tbody>
            <% @data[:top_referrers].each_with_index do |ref, i| %>
              <tr class="border-b border-gray-50 last:border-0">
                <td class="px-5 py-2.5 text-gray-400 tabular-nums"><%= i + 1 %></td>
                <td class="px-5 py-2.5 font-medium text-gray-900"><%= ref[:referral_code] %></td>
                <td class="px-5 py-2.5 text-right text-gray-600 tabular-nums"><%= ref[:usage_count] %></td>
                <td class="px-5 py-2.5 text-right text-gray-600 tabular-nums"><%= format_analytics_currency(ref[:revenue]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

  <% end %>
</div>
